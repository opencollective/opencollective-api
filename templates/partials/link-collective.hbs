{{! Partials are not isolated properly in handlebars, they inherit the context of the parent template. We use _parentCollective to prevent it from being wrongly injected from the parent context. }}
{{~#if _parentCollective~}}
  <a href="{{accountUrl collective _parentCollective}}">
    {{~#if text}}{{text}}
    {{else}}
      {{~#if _parentCollective}}{{#if _parentCollective.name}}{{_parentCollective.name}}{{else}}{{_parentCollective.slug}}{{/if}} → {{/if~}}
      {{~#if collective.name}}{{collective.name}}{{else}}{{collective.slug}}{{/if~}}
    {{~/if~}}
  </a>
{{~else~}}
  <a href="{{accountUrl collective}}">{{#if text}}{{text}}{{else if collective.name}}{{collective.name}}{{else}}{{collective.slug}}{{/if}}</a>
{{~/if}}
